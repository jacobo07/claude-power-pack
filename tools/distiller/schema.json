{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kobiidistilleros://schema/v1",
  "version": "1.1.0",
  "description": "KobiiDistillerOS output contract. Verbatim markers from Dataset KobiiDistillerOS 1.txt + mandatory per-section blocks + forbidden-token + redaction patterns.",

  "tier_layout": {
    "Tier_1": {
      "label": "Pipeline & Arquitectura",
      "sections": [1, 2, 3, 4, 5, 6, 7],
      "end_marker": "-- FIN DE TIER 1 --"
    },
    "Tier_2": {
      "label": "Gobernanza",
      "sections": [8, 9, 10, 11, 12, 13],
      "end_marker": "-- FIN DE TIER 2 --"
    },
    "Tier_3": {
      "label": "Interfaz & Materialización",
      "sections": [14, 15, 16, 17, 18, 19],
      "end_marker": "-- FIN DE TIER 3 --"
    }
  },

  "dataset_final_marker": "-- FIN DE DATASET v1.0 --",

  "section_count": 19,

  "section_titles": {
    "1":  "Resumen General (Arquitectónico)",
    "2":  "Ideas Accionables (POR TANDAS)",
    "3":  "Frameworks y Modelos Mentales",
    "4":  "Estrategias (SOPs + Árboles de Decisión)",
    "5":  "Patrones, Leyes Ocultas y Principios",
    "6":  "Señales Sociales y Juegos de Poder",
    "7":  "Citas Clave (DESTILADAS)",
    "8":  "Errores, Sesgos y Anti-Patrones",
    "9":  "Agentes y Workflows (CREACIÓN DIRECTA DESDE EL DATASET)",
    "10": "Funciones Nuevas para SaaS y Sistemas IA Empresariales",
    "11": "Servicios Nuevos y Océanos Azules (APLICABLE A LOS PROYECTOS DEL USUARIO)",
    "12": "Síntesis para Entrenamiento Profundo",
    "13": "Integración Multi-Sistema (InfinityOps Core)",
    "14": "<<AWAITING OWNER VERBATIM — Q1.a>>",
    "15": "<<AWAITING OWNER VERBATIM — Q1.a>>",
    "16": "<<AWAITING OWNER VERBATIM — Q1.a>>",
    "17": "Pensamiento arborescente (otros contextos y propósitos de negocio)",
    "18": "ROI del Dataset (tiempo/dinero/riesgo) — CON FREEZE GATE",
    "19": "Plan de acción con el dataset (operativo + ejecución)"
  },

  "required_section_blocks": {
    "heading_regex": "^##\\s+\\d{1,2}\\.\\s+.+$",
    "roi_block": {
      "marker": "🧮 Calculadora de ROI",
      "required_fields": ["Tipo", "ROI Temporal", "ROI Riesgo", "Escenario", "Explicación"]
    },
    "closing_marker": "🏁 Cierre patrimonial",
    "oracle_aside": "🦅 Comentario del Oráculo"
  },

  "forbidden_tokens": [
    "TODO",
    "FIXME",
    "HACK",
    "PLACEHOLDER",
    "Coming Soon",
    "coming soon",
    "<TU_URL_REAL>",
    "<TU_TOKEN>",
    "<TU_SECRETO>",
    "raise NotImplementedError",
    "pass # TODO",
    "// TODO",
    "/* TODO */",
    "Placeholder"
  ],

  "redaction_patterns": {
    "discord_webhook": "https://discord(?:app)?\\.com/api/webhooks/\\d+/[A-Za-z0-9_-]+",
    "ssh_private_key": "-----BEGIN (?:OPENSSH|RSA|EC|DSA) PRIVATE KEY-----[\\s\\S]+?-----END (?:OPENSSH|RSA|EC|DSA) PRIVATE KEY-----",
    "ssh_key_path": "~?/?\\.ssh/[A-Za-z0-9_.-]+",
    "kobicraft_token": "kobicraft_[A-Za-z0-9_-]{6,}",
    "aws_access_key": "AKIA[A-Z0-9]{16}",
    "github_pat": "gh[ps]_[A-Za-z0-9]{36,}",
    "bearer_jwt": "Bearer\\s+ey[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+",
    "generic_api_key_kv": "(?i)(?:api[_-]?key|secret[_-]?key|access[_-]?token)\\s*[:=]\\s*['\"]?[A-Za-z0-9_-]{16,}['\"]?"
  },

  "voice_gate": {
    "_comment": "G4 audit fix — author-judgment lists ship as ADVISORY (validator emits warnings, not exit 5) until Owner ratifies. Phase C promotes to enforcing mode by flipping `mode` to `enforcing`.",
    "mode": "advisory",
    "exit_code_when_enforcing": 5,
    "blacklist_candidates": [
      "KPI",
      "synergy",
      "leverage",
      "stakeholder",
      "deliverable",
      "roadmap",
      "actionable",
      "seamless",
      "cutting-edge",
      "value-add",
      "low-hanging fruit",
      "paradigm shift",
      "holistic",
      "best-in-class",
      "world-class",
      "game-changer",
      "productize",
      "enablement",
      "north star metric"
    ],
    "anchors_candidates": [
      "Refugio",
      "refugio",
      "MCPE",
      "Hytale",
      "2014",
      "2010",
      "2012",
      "infancia",
      "abuelo",
      "abuela",
      "cabaña",
      "linterna",
      "Nostalgia",
      "nostalgia",
      "Helsinki",
      "MundiCraft",
      "KobiiCraft",
      "KobiiClaw",
      "Mundial",
      "Azteca",
      "Andorra"
    ]
  },

  "kill_switch_marker": "🧨 KILL-SWITCH",

  "ingestor_limits": {
    "max_input_bytes": 1048576,
    "force_flag_required_above_cap": true,
    "chunk_strategy": "heading_then_block",
    "chunk_heading_regex": "^##\\s+.+$",
    "chunk_fallback_block_bytes": 51200
  }
}
