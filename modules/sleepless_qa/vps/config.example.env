# Sleepless QA — systemd EnvironmentFile template.
# Copy to /etc/sleepless-qa.env (root:root, mode 600) and fill values.

# REQUIRED — same key used by omnicapture/autoresearch on this VPS.
ANTHROPIC_API_KEY=

# Target VPS context (informational — sleepless-qa itself runs locally).
VPS_HOST=kobiiclaw-vps

# Override default state dir (~/.claude/sleepless-qa)
# QA_STATE_DIR=/var/lib/sleepless-qa

# Healing loop retry budget (default 3). Higher = more auto-fix runway.
MAX_RETRY_BUDGET=3

# Confidence threshold below which verdicts become UNCERTAIN and trigger
# desktop notification instead of auto-heal. Default 0.7.
UNCERTAIN_THRESHOLD=0.7

# Subprocess timeout for target runtimes (seconds). Default 600 (10 min).
SUBPROCESS_TIMEOUT_SECONDS=600
