__pycache__/
*.pyc
BLOCKED_DELIVERY.md
*.v7-monolith-backup
_knowledge_graph/
_audit_cache/*
!_audit_cache/semantic_tags.json

# npm-managed deps (provisioned by install.sh / install.ps1, not vendored in git)
node_modules/
package-lock.json
npm-debug.log*

# OVO session markers (power-pack scoped; hook reads at repo root)
/.ovo_active

# SessionStart hub health-check runtime evidence (BL-TOOL-AUTO-001)
vault/health/*.last.txt
/.ovo_inactive

# OVO snapshot artifacts (generated per audit; only .gitkeep and verdicts.jsonl tracked)
vault/audits/snapshots/source_map_*.json
vault/audits/ovo_*.json
vault/audits/ovo_*.md

# v230000 — kpp-distiller-kernel pip-installable package artifacts
kpp-distiller-kernel/*.egg-info/
kpp-distiller-kernel/**/*.egg-info/
kpp-distiller-kernel/build/
kpp-distiller-kernel/dist/
kpp-distiller-kernel/**/__pycache__/
kpp-distiller-kernel/**/*.pyc
/_quarantine/
/lib/

# Programmatic-budget layer (P3/P3b/P1) — session-generated, never committed
vault/cache_hints/*.json
vault/telemetry/rtk_*.jsonl
vault/telemetry/budget-*.jsonl
tests/auto-generated/

# Architecture Decision Skill — host-specific generated index (regenerated
# by build_index.py; contains absolute paths). Decisions themselves ARE
# tracked.
vault/.arch-index/

# Backup Axis -- repo-root local snapshot dir; never commit raw
# backup bytes. The receipts under vault/backups/ ARE tracked
# (audit trail); the snapshots themselves stay local-only per spec
# backup-skill.md §11. Anchor the pattern at the repo root so
# vault/backups/ stays tracked.
/backups/

# CPC-OS crash-restore auto-writer artifacts (session-specific: regenerated
# every 15 min by tools/snapshot_auto_writer.ps1 and carry rotating session
# UUIDs -- never version-control them).
.vscode/tasks.json
.vscode/tasks.json.cpc-bak
vault/setup_os/profiles/

# Cognitive OS (CO-01) Work-Unit ledger -- append-only runtime telemetry fed by
# done-gate verdicts; accumulates per-session and would churn/conflict across
# panes. Local-only, like vault/ceps + vault/token_logs.
vault/cognitive_os/wu_ledger.jsonl
